# NextGen BPO Intelligence Platform — Environment Variables
# Copy to .env for local development

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (Railway assigns PORT automatically)
PORT=3031

# Environment
NODE_ENV=development

# Authentication (set these on Railway)
TOKEN_SECRET=your-very-long-random-secret-here
CLIENT_NAME=YourClientName
CLIENT_PASSWORD=YourSecurePassword
PROTECTED_MODE=true
